<Project Sdk="Microsoft.NET.Sdk">

  <Sdk Name="Cosmos.Sdk" Version="3.0.48" />

  <PropertyGroup>
    <CosmosEnableNetwork>false</CosmosEnableNetwork>
    <CosmosKernelClass>Yukihana.Kernel</CosmosKernelClass>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <!-- Generate version info -->
  <PropertyGroup>
    <Year>$([System.DateTime]::Now.ToString("yyyy"))</Year>
    <Month>$([System.DateTime]::Now.ToString("MM"))</Month>
    <Day>$([System.DateTime]::Now.ToString("dd"))</Day>
    <Time>$([System.DateTime]::Now.ToString("HHmm"))</Time>

    <CosmosVersion>3.0.48</CosmosVersion>
    <YukihanaVersion>2.0.13</YukihanaVersion>

    <YukihanaVersionInfo>
      <![CDATA[
// Yukihana OS 2026 Yukihana OS Contributors
// Licensed under the Apache 2.0 License. See LICENSE for details.

// This file is auto-generated. Do not edit.

namespace Yukihana.Core.Generated%3b

public static class VersionInfo
{
    public const string KERNEL_NAME = "CosmosOS"%3b
    public const string KERNEL_VERSION = "$(CosmosVersion)"%3b

    public const string OS_NAME = "Yukihana"%3b
    public const string OS_VERSION = "$(YukihanaVersion)"%3b
    public const string OS_REVISION = "rev-$(Year)$(Month)$(Day)$(Time)"%3b
}]]>
    </YukihanaVersionInfo>
  </PropertyGroup>

  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <WriteLinesToFile File="Core/Generated/VersionInfo.cs" Lines="$(YukihanaVersionInfo)" Overwrite="true" />
  </Target>

  
  <!-- Core kernel packages -->
  <ItemGroup>
    <PackageReference Include="Cosmos.Kernel" Version="3.0.48" />
    <PackageReference Include="Cosmos.Kernel.System" Version="3.0.48" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Core/Resources/initramfs.cpio.gz" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SharpZipLib" Version="1.4.2" />
  </ItemGroup>

</Project>
